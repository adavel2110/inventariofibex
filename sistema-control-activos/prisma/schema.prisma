generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CONFIGURACIÓN Y CATÁLOGOS PARAMETRIZABLES
// ============================================

model TipoParametrico {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  descripcion   String?
  modulo        String    // inventario, despacho, asignacion, etc.
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  valores       ValorParametrico[]

  @@map("tipos_parametricos")
}

model ValorParametrico {
  id              String    @id @default(uuid())
  tipoParametricoId String
  tipoParametrico TipoParametrico @relation(fields: [tipoParametricoId], references: [id])
  codigo          String
  nombre          String
  descripcion     String?
  orden           Int       @default(0)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tipoParametricoId, codigo])
  @@map("valores_parametricos")
}

model Configuracion {
  id            String   @id @default(uuid())
  clave         String   @unique
  valor         String
  descripcion   String?
  categoria     String
  editable      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  updatedById   String?
  updatedBy     Usuario? @relation("ConfigUpdatedBy", fields: [updatedById], references: [id])

  @@map("configuraciones")
}

model Sede {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  direccion     String?
  ciudad        String
  estado        String
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  departamentos Departamento[]
  empleados     Empleado[]
  stockItems    StockItem[]
  
  @@map("sedes")
}

model Departamento {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  sedeId        String
  sede          Sede      @relation(fields: [sedeId], references: [id])
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  empleados     Empleado[]
  
  @@map("departamentos")
}

model Categoria {
  id                String    @id @default(uuid())
  codigo            String    @unique
  nombre            String
  descripcion       String?
  tipo              String    // Dinámico: EQUIPO_COMPUTO, PERIFERICO, CONSUMIBLE, etc.
  esDepreciable     Boolean   @default(false)
  vidaUtilMeses     Int?
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  productos         Producto[]
  modelos           Modelo[]

  @@map("categorias")
}

model Marca {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  modelos       Modelo[]
  
  @@map("marcas")
}

model Modelo {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  marcaId       String
  marca         Marca     @relation(fields: [marcaId], references: [id])
  categoriaId   String
  categoria     Categoria @relation(fields: [categoriaId], references: [id])
  especificaciones Json?
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  productos     Producto[]
  
  @@map("modelos")
}

model Producto {
  id                String    @id @default(uuid())
  codigo            String    @unique
  sku               String?   @unique
  nombre            String
  descripcion       String?
  categoriaId       String
  categoria         Categoria @relation(fields: [categoriaId], references: [id])
  modeloId          String?
  modelo            Modelo?   @relation(fields: [modeloId], references: [id])
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  stockItems        StockItem[]
  despachoItems     DespachoItem[]
  
  @@map("productos")
}

// ============================================
// USUARIOS Y ROLES (RBAC)
// ============================================

model Rol {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  descripcion   String?
  permisos      Permiso[]
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  usuarios      Usuario[]
  
  @@map("roles")
}

model Permiso {
  id            String    @id @default(uuid())
  codigo        String    @unique
  nombre        String
  descripcion   String?
  modulo        String
  accion        String
  roles         Rol[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("permisos")
}

model Usuario {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  nombre            String
  apellido          String
  cargo             String?
  telefono          String?
  avatar            String?
  rolId             String
  rol               Rol       @relation(fields: [rolId], references: [id])
  empleadoId        String?   @unique
  empleado          Empleado? @relation(fields: [empleadoId], references: [id])
  activo            Boolean   @default(true)
  ultimoAcceso      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Auditoría
  auditoriasCreadas   Auditoria[] @relation("AuditoriaCreatedBy")
  auditoriasUpdated   Auditoria[] @relation("AuditoriaUpdatedBy")
  configuraciones     Configuracion[] @relation("ConfigUpdatedBy")
  
  // Despachos
  despachosSolicitados Despacho[] @relation("DespachoSolicitadoPor")
  despachosAprobados   Despacho[] @relation("DespachoAprobadoPor")
  despachosEntregados  Despacho[] @relation("DespachoEntregadoPor")
  
  // Asignaciones
  asignacionesEntregadas Asignacion[] @relation("AsignacionEntregadoPor")
  asignacionesRecibidas  Asignacion[] @relation("AsignacionRecibidoPor")
  
  @@map("usuarios")
}

// ============================================
// EMPLEADOS
// ============================================

model Empleado {
  id                String    @id @default(uuid())
  codigo            String    @unique
  cedula            String    @unique
  nombre            String
  apellido          String
  email             String    @unique
  telefono          String?
  cargo             String
  departamentoId    String
  departamento      Departamento @relation(fields: [departamentoId], references: [id])
  sedeId            String
  sede              Sede      @relation(fields: [sedeId], references: [id])
  fechaIngreso      DateTime
  fechaEgreso       DateTime?
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  usuario           Usuario?
  asignaciones      Asignacion[]
  despachos         Despacho[] @relation("DespachoSolicitante")
  
  @@map("empleados")
}

// ============================================
// INVENTARIO Y STOCK
// ============================================

model StockItem {
  id                String    @id @default(uuid())
  codigoBarras      String?   @unique
  qrCode            String?   @unique
  productoId        String
  producto          Producto  @relation(fields: [productoId], references: [id])
  numeroSerie       String?
  imei              String?
  macAddress        String?
  
  // Ubicación
  sedeId            String?
  sede              Sede?     @relation(fields: [sedeId], references: [id])
  ubicacionFisica   String?
  
  // Estados
  estado            EstadoStock @default(DISPONIBLE)
  condicion         CondicionEquipo @default(NUEVO)
  
  // Información de adquisición
  fechaIngreso      DateTime  @default(now())
  fechaCompra       DateTime?
  numeroFactura     String?
  costo             Decimal?  @db.Decimal(12, 2)
  proveedor         String?
  
  // Garantía
  garantiaHasta     DateTime?
  
  // Especificaciones adicionales (para PCs, Laptops)
  nombreEquipo      String?
  os                String?
  cpu               String?
  memoriaGb         String?
  disco             String?
  ipAsignada        String?
  password          String?
  observaciones     String?
  
  // Relación con equipo padre (para periféricos)
  equipoPadreId     String?
  equipoPadre       StockItem?  @relation("PerifericosEquipo", fields: [equipoPadreId], references: [id])
  perifericos       StockItem[] @relation("PerifericosEquipo")
  
  // Control de version
  version           Int       @default(1)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relaciones
  asignaciones      Asignacion[]
  mantenimientos    Mantenimiento[]
  
  @@map("stock_items")
}

model Mantenimiento {
  id                String    @id @default(uuid())
  stockItemId       String
  stockItem         StockItem @relation(fields: [stockItemId], references: [id])
  tipo              TipoMantenimiento
  fecha             DateTime
  descripcion       String
  realizadoPor      String
  costo             Decimal?  @db.Decimal(12, 2)
  proximoMantenimiento DateTime?
  observaciones     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("mantenimientos")
}

// ============================================
// ASIGNACIONES A EMPLEADOS
// ============================================

model Asignacion {
  id                String    @id @default(uuid())
  codigo            String    @unique
  
  // Equipo asignado
  stockItemId       String
  stockItem         StockItem @relation(fields: [stockItemId], references: [id])
  
  // Empleado
  empleadoId        String
  empleado          Empleado  @relation(fields: [empleadoId], references: [id])
  
  // Fechas
  fechaAsignacion   DateTime
  fechaDevolucion   DateTime?
  fechaExpiracion   DateTime?
  
  // Condiciones
  condicionEntrega  CondicionEquipo
  condicionDevolucion CondicionEquipo?
  
  // Responsables
  entregadoPorId    String
  entregadoPor      Usuario   @relation("AsignacionEntregadoPor", fields: [entregadoPorId], references: [id])
  recibidoPorId     String?
  recibidoPor       Usuario?  @relation("AsignacionRecibidoPor", fields: [recibidoPorId], references: [id])
  
  // Documentación
  observaciones     String?
  documentoUrl      String?
  firmaDigital      String?
  
  // Estado
  estado            EstadoAsignacion @default(ACTIVA)
  
  // Relación con despacho (si aplica)
  despachoId        String?
  despacho          Despacho? @relation(fields: [despachoId], references: [id])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("asignaciones")
}

// ============================================
// DESPACHOS (SOLICITUDES Y ENTREGAS)
// ============================================

model Despacho {
  id                String    @id @default(uuid())
  codigo            String    @unique
  
  // Tipo y estado
  tipo              TipoDespacho
  estado            EstadoDespacho @default(PENDIENTE)
  prioridad         PrioridadDespacho @default(NORMAL)
  
  // Solicitante
  solicitanteId     String
  solicitante       Empleado  @relation("DespachoSolicitante", fields: [solicitanteId], references: [id])
  
  // Fechas del flujo
  fechaSolicitud    DateTime  @default(now())
  fechaRequerida    DateTime?
  fechaAprobacion   DateTime?
  fechaEntrega      DateTime?
  
  // Aprobación
  aprobadoPorId     String?
  aprobadoPor       Usuario?  @relation("DespachoAprobadoPor", fields: [aprobadoPorId], references: [id])
  
  // Entrega
  entregadoPorId    String?
  entregadoPor      Usuario?  @relation("DespachoEntregadoPor", fields: [entregadoPorId], references: [id])
  
  // Motivo y observaciones
  motivo            String
  observaciones     String?
  observacionesAprobacion String?
  observacionesEntrega    String?
  
  // Items del despacho
  items             DespachoItem[]
  
  // Asignaciones generadas
  asignaciones      Asignacion[]
  
  // Quien creó el despacho (usuario que lo registró)
  creadoPorId       String?
  creadoPor         Usuario?  @relation("DespachoSolicitadoPor", fields: [creadoPorId], references: [id])
  
  // QR del despacho completo
  qrCode            String?   @unique
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("despachos")
}

model DespachoItem {
  id                String    @id @default(uuid())
  despachoId        String
  despacho          Despacho  @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  
  // Producto solicitado
  productoId        String
  producto          Producto  @relation(fields: [productoId], references: [id])
  cantidadSolicitada Int
  cantidadEntregada Int       @default(0)
  
  // Stock items específicos asignados (para equipos con serie)
  stockItems        Json?     // Array de IDs de StockItem asignados
  
  // Observaciones específicas del item
  observaciones     String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("despacho_items")
}

// ============================================
// AUDITORÍA COMPLETA
// ============================================

model Auditoria {
  id                String    @id @default(uuid())
  
  // Entidad auditada
  tabla             String
  registroId        String
  accion            TipoAccionAuditoria
  
  // Datos
  datosAnteriores   Json?
  datosNuevos       Json?
  
  // Usuario
  usuarioId         String
  usuario           Usuario   @relation("AuditoriaCreatedBy", fields: [usuarioId], references: [id])
  
  // Contexto
  ipAddress         String?
  userAgent         String?
  endpoint          String?
  
  // Para cambios que requieren aprobación
  aprobadoPorId     String?
  aprobadoPor       Usuario?  @relation("AuditoriaUpdatedBy", fields: [aprobadoPorId], references: [id])
  
  createdAt         DateTime  @default(now())
  
  @@index([tabla, registroId])
  @@index([createdAt])
  @@index([usuarioId])
  @@map("auditorias")
}

// ============================================
// ENUMS (los que bleiben fixed)
// ============================================

enum EstadoStock {
  DISPONIBLE
  ASIGNADO
  EN_REPARACION
  EN_DESPACHO
  DADO_BAJA
  EN_TRANSITO
  RESERVADO
}

enum CondicionEquipo {
  NUEVO
  USADO_BUENO
  USADO_REGULAR
  MALO
  EN_REPARACION
  OBSOLETO
}

enum EstadoAsignacion {
  ACTIVA
  DEVUELTA
  PERDIDA
  DANADA
  VENCIDA
}

enum TipoMantenimiento {
  PREVENTIVO
  CORRECTIVO
  ACTUALIZACION
  LIMPIEZA
  REVISION
}

enum TipoDespacho {
  NUEVA_ASIGNACION
  REEMPLAZO
  PRESTAMO
  REPARACION
  DEVOLUCION
  CONSUMIBLES
}

enum EstadoDespacho {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
  EN_PREPARACION
  LISTO_ENTREGA
  ENTREGADO
  CANCELADO
}

enum PrioridadDespacho {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

enum TipoAccionAuditoria {
  CREAR
  ACTUALIZAR
  ELIMINAR
  LOGIN
  LOGOUT
  EXPORTAR
  IMPORTAR
  APROBAR
  RECHAZAR
  ENTREGAR
  DEVOLVER
}
